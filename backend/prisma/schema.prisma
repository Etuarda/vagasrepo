datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String @id @default(uuid())
  name         String
  email        String @unique
  password     String
  title        String @default("")
  emailContact String @default("")
  phone        String @default("")
  location     String @default("")
  linkedin     String @default("")
  github       String @default("")
  summary      String @default("")

  jobs             Job[]
  skills           Skill[]
  projects         Project[]
  experiences      Experience[]
  optimizedResumes OptimizedResume[]
  resumeFiles      ResumeFile[]
}

model Job {
  id       String @id @default(uuid())
  titulo   String
  empresa  String
  linkVaga String
  linkCV   String

  data   DateTime
  status String
  fase   String

  acaoNecessaria Boolean
  qualAcao       String?
  prazoAcao      DateTime?

  feedbackBool Boolean
  feedbackTxt  String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([fase])
}

model Skill {
  id        String   @id @default(uuid())
  name      String
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  technologies ProjectTechnology[]

  @@index([userId])
}

model ProjectTechnology {
  id        String @id @default(uuid())
  name      String
  projectId String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@index([projectId])
}

model Experience {
  id          String   @id @default(uuid())
  company     String
  role        String
  period      String
  description String
  userId      String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OptimizedResume {
  id                  String   @id @default(uuid())
  userId              String
  targetTitle         String
  jobDescription      String
  score               Int
  suggestedSummary    String
  selectedProjects    Json
  matchedSkills       String[] @default([])
  missingSkills       String[] @default([])
  matchedTechnologies String[] @default([])
  missingTechnologies String[] @default([])
  resumeFileId        String?
  generatedPdf        Bytes?
  generatedFileName   String?
  createdAt           DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeFile ResumeFile? @relation(fields: [resumeFileId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([resumeFileId])
  @@index([createdAt])
}

model ResumeFile {
  id            String   @id @default(uuid())
  userId        String
  fileName      String
  mimeType      String
  sizeBytes     Int
  content       Bytes
  extractedText String   @default("")
  createdAt     DateTime @default(now())

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  optimizedResumes OptimizedResume[]

  @@index([userId])
  @@index([createdAt])
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String @id @default(uuid())
  name         String
  email        String @unique
  password     String
  title        String @default("")
  emailContact String @default("")
  phone        String @default("")
  cpfCnpj      String @default("")
  location     String @default("")
  cep          String @default("")
  linkedin     String @default("")
  github       String @default("")
  lattes       String @default("")
  summary      String @default("")

  jobs                Job[]
  careerProfiles      CareerProfile[]
  skills              Skill[]
  projects            Project[]
  experiences         Experience[]
  courses             Course[]
  certifications      Certification[]
  languages           Language[]
  educations          Education[]
  jobAnalyses         JobAnalysis[]
  optimizedResumes    OptimizedResume[]
  resumeFiles         ResumeFile[]
  authSessions        AuthSession[]
  passwordResetTokens PasswordResetToken[]
  subscription        Subscription?
  usageCounters       UsageCounter[]
  billingEvents       BillingEvent[]
  couponRedemptions   CouponRedemption[]
  applicationStatusHistory ApplicationStatusHistory[]
}

model Subscription {
  id                     String    @id @default(uuid())
  userId                 String    @unique
  plan                   String    @default("free")
  status                 String    @default("active")
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  provider               String?
  providerCustomerId     String?
  providerSubscriptionId String?
  providerPaymentId      String?
  checkoutUrl            String?
  lastPaymentStatus      String?
  pendingPlan            String?
  couponId               String?
  originalPriceCents     Int?
  finalPriceCents        Int?
  discountCents          Int?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon            Coupon?            @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponRedemptions CouponRedemption[]

  @@index([plan])
  @@index([status])
  @@index([providerCustomerId])
  @@index([providerSubscriptionId])
  @@index([providerPaymentId])
  @@index([couponId])
}

model UsageCounter {
  id        String   @id @default(uuid())
  userId    String
  feature   String
  periodKey String
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, feature, periodKey])
  @@index([userId])
}

model BillingEvent {
  id          String    @id @default(uuid())
  provider    String
  eventId     String
  eventType   String
  userId      String?
  payload     Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([provider, eventId])
  @@index([userId])
  @@index([eventType])
}

model Coupon {
  id                    String    @id @default(uuid())
  code                  String    @unique
  description           String?
  type                  String
  value                 Int
  maxDiscountCents      Int?
  appliesToPlans        String[]  @default([])
  duration              String    @default("once")
  maxRedemptions        Int?
  redeemedCount         Int       @default(0)
  maxRedemptionsPerUser Int?      @default(1)
  startsAt              DateTime?
  expiresAt             DateTime?
  active                Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  subscriptions Subscription[]
  redemptions   CouponRedemption[]

  @@index([active])
  @@index([expiresAt])
}

model CouponRedemption {
  id                 String   @id @default(uuid())
  couponId           String
  userId             String
  subscriptionId     String?
  plan               String
  originalPriceCents Int
  discountCents      Int
  finalPriceCents    Int
  redeemedAt         DateTime @default(now())

  coupon       Coupon        @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@unique([couponId, subscriptionId])
  @@index([couponId])
  @@index([userId])
  @@index([subscriptionId])
  @@index([couponId, userId])
}

model CareerProfile {
  id           String   @id @default(uuid())
  userId       String
  profileName  String
  isGlobal     Boolean  @default(false)
  name         String
  title        String   @default("")
  emailContact String   @default("")
  phone        String   @default("")
  location     String   @default("")
  cep          String   @default("")
  linkedin     String   @default("")
  github       String   @default("")
  lattes       String   @default("")
  summary      String   @default("")
  objective    String   @default("")
  seniority    String   @default("")
  category     String   @default("unknown")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user                     User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills                   Skill[]
  projects                 Project[]
  experiences              Experience[]
  courses                  Course[]
  certifications           Certification[]
  languages                Language[]
  educations               Education[]
  subprofileSkills         SubprofileSkill[]
  subprofileProjects       SubprofileProject[]
  subprofileExperiences    SubprofileExperience[]
  subprofileCourses        SubprofileCourse[]
  subprofileCertifications SubprofileCertification[]
  subprofileEducations     SubprofileEducation[]
  subprofileLanguages      SubprofileLanguage[]
  selectedJobAnalyses      JobAnalysis[]
  optimizedResumes         OptimizedResume[]
  resumeFiles              ResumeFile[]

  @@index([userId])
}

model Job {
  id                String  @id @default(uuid())
  titulo            String
  empresa           String
  linkVaga          String
  linkCV            String
  jobDescription    String  @default("")
  notes             String  @default("")
  jobAnalysisId     String?
  optimizedResumeId String?

  data   DateTime
  status String
  fase   String

  acaoNecessaria Boolean
  qualAcao       String?
  prazoAcao      DateTime?

  feedbackBool Boolean
  feedbackTxt  String?

  userId          String
  user            User             @relation(fields: [userId], references: [id])
  jobAnalysis     JobAnalysis?     @relation(fields: [jobAnalysisId], references: [id], onDelete: SetNull)
  optimizedResume OptimizedResume? @relation("ApplicationResume", fields: [optimizedResumeId], references: [id], onDelete: SetNull)
  statusHistory   ApplicationStatusHistory[]

  @@index([userId])
  @@index([userId, data])
  @@index([status])
  @@index([fase])
  @@index([jobAnalysisId])
  @@index([optimizedResumeId])
}

model ApplicationStatusHistory {
  id             String   @id @default(uuid())
  userId         String
  jobId          String
  statusAnterior String   @default("")
  novoStatus     String   @default("")
  faseAnterior   String   @default("")
  novaFase       String   @default("")
  observacao     String   @default("")
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jobId])
  @@index([createdAt])
}

model AuthSession {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Skill {
  id             String   @id @default(uuid())
  name           String
  normalizedName String   @default("")
  category       String   @default("other")
  userId         String
  profileId      String?
  createdAt      DateTime @default(now())

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile     CareerProfile?    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  subprofiles SubprofileSkill[]

  @@unique([profileId, name])
  @@index([userId])
  @@index([profileId])
}

model Project {
  id                String   @id @default(uuid())
  title             String
  description       String
  category          String   @default("other")
  shortDescription  String   @default("")
  businessProblem   String   @default("")
  technicalSolution String   @default("")
  architecture      String   @default("")
  stack             String   @default("")
  learnedSkills     String[] @default([])
  repositoryUrl     String   @default("")
  deployUrl         String   @default("")
  userId            String
  profileId         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile      CareerProfile?      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  technologies ProjectTechnology[]
  bullets      ProjectBullet[]
  subprofiles  SubprofileProject[]

  @@index([userId])
  @@index([profileId])
}

model ProjectTechnology {
  id             String @id @default(uuid())
  name           String
  normalizedName String @default("")
  category       String @default("other")
  projectId      String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@index([projectId])
}

model ProjectBullet {
  id        String   @id @default(uuid())
  projectId String
  category  String   @default("backend")
  content   String
  keywords  String[] @default([])
  weight    Int      @default(50)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Experience {
  id          String   @id @default(uuid())
  company     String
  role        String
  period      String
  workload    String   @default("")
  description String
  userId      String
  profileId   String?
  createdAt   DateTime @default(now())

  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile     CareerProfile?         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  subprofiles SubprofileExperience[]

  @@index([userId])
  @@index([profileId])
}

model Course {
  id          String   @id @default(uuid())
  title       String
  institution String   @default("")
  period      String   @default("")
  workload    String   @default("")
  description String   @default("")
  learnedSkills String[] @default([])
  userId      String
  profileId   String?
  createdAt   DateTime @default(now())

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile     CareerProfile?     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  subprofiles SubprofileCourse[]

  @@index([userId])
  @@index([profileId])
}

model Certification {
  id            String   @id @default(uuid())
  title         String
  issuer        String   @default("")
  period        String   @default("")
  workload      String   @default("")
  credentialUrl String   @default("")
  learnedSkills String[] @default([])
  userId        String
  profileId     String?
  createdAt     DateTime @default(now())

  user        User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile     CareerProfile?            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  subprofiles SubprofileCertification[]

  @@index([userId])
  @@index([profileId])
}

model Language {
  id        String   @id @default(uuid())
  name      String
  level     String   @default("")
  userId    String
  profileId String?
  createdAt DateTime @default(now())

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile     CareerProfile?       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  subprofiles SubprofileLanguage[]

  @@index([userId])
  @@index([profileId])
}

model Education {
  id          String   @id @default(uuid())
  title       String
  institution String
  period      String   @default("")
  learnedSkills String[] @default([])
  userId      String
  profileId   String?
  createdAt   DateTime @default(now())

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile     CareerProfile?        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  subprofiles SubprofileEducation[]

  @@index([userId])
  @@index([profileId])
}

model SubprofileSkill {
  id              String  @id @default(uuid())
  subprofileId    String
  skillId         String
  relevanceWeight Int     @default(50)
  isVisible       Boolean @default(true)

  subprofile CareerProfile @relation(fields: [subprofileId], references: [id], onDelete: Cascade)
  skill      Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([subprofileId, skillId])
  @@index([skillId])
}

model SubprofileProject {
  id              String  @id @default(uuid())
  subprofileId    String
  projectId       String
  customTitle     String  @default("")
  customSummary   String  @default("")
  customBullets   Json?
  relevanceWeight Int     @default(50)
  isVisible       Boolean @default(true)

  subprofile CareerProfile @relation(fields: [subprofileId], references: [id], onDelete: Cascade)
  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([subprofileId, projectId])
  @@index([projectId])
}

model SubprofileExperience {
  id              String  @id @default(uuid())
  subprofileId    String
  experienceId    String
  customBullets   Json?
  relevanceWeight Int     @default(50)
  isVisible       Boolean @default(true)

  subprofile CareerProfile @relation(fields: [subprofileId], references: [id], onDelete: Cascade)
  experience Experience    @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  @@unique([subprofileId, experienceId])
  @@index([experienceId])
}

model SubprofileCourse {
  id              String  @id @default(uuid())
  subprofileId    String
  courseId        String
  relevanceWeight Int     @default(50)
  isVisible       Boolean @default(true)

  subprofile CareerProfile @relation(fields: [subprofileId], references: [id], onDelete: Cascade)
  course     Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([subprofileId, courseId])
  @@index([courseId])
}

model SubprofileCertification {
  id              String  @id @default(uuid())
  subprofileId    String
  certificationId String
  relevanceWeight Int     @default(50)
  isVisible       Boolean @default(true)

  subprofile    CareerProfile @relation(fields: [subprofileId], references: [id], onDelete: Cascade)
  certification Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)

  @@unique([subprofileId, certificationId])
  @@index([certificationId])
}

model SubprofileEducation {
  id           String  @id @default(uuid())
  subprofileId String
  educationId  String
  isVisible    Boolean @default(true)

  subprofile CareerProfile @relation(fields: [subprofileId], references: [id], onDelete: Cascade)
  education  Education     @relation(fields: [educationId], references: [id], onDelete: Cascade)

  @@unique([subprofileId, educationId])
  @@index([educationId])
}

model SubprofileLanguage {
  id           String  @id @default(uuid())
  subprofileId String
  languageId   String
  isVisible    Boolean @default(true)

  subprofile CareerProfile @relation(fields: [subprofileId], references: [id], onDelete: Cascade)
  language   Language      @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([subprofileId, languageId])
  @@index([languageId])
}

model OptimizedResume {
  id                  String   @id @default(uuid())
  userId              String
  targetTitle         String
  jobDescription      String
  score               Int
  suggestedSummary    String
  selectedProjects    Json
  matchedSkills       String[] @default([])
  missingSkills       String[] @default([])
  matchedTechnologies String[] @default([])
  missingTechnologies String[] @default([])
  resumeFileId        String?
  profileId           String?
  generatedPdf        Bytes?
  generatedFileName   String?
  createdAt           DateTime @default(now())

  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile              CareerProfile?     @relation(fields: [profileId], references: [id], onDelete: SetNull)
  resumeFile           ResumeFile?        @relation(fields: [resumeFileId], references: [id], onDelete: SetNull)
  generatedForAnalyses JobAnalysis[]      @relation("GeneratedAnalysisResume")
  googleDocsExports    GoogleDocsExport[]
  applications         Job[]              @relation("ApplicationResume")

  @@index([userId])
  @@index([profileId])
  @@index([resumeFileId])
  @@index([createdAt])
}

model JobAnalysis {
  id                   String    @id @default(uuid())
  userId               String
  jobTitle             String
  company              String    @default("")
  jobUrl               String    @default("")
  jobDescription       String
  selectedSubprofileId String?
  matchScore           Int
  jobCategory          String    @default("unknown")
  matchedSkills        String[]  @default([])
  missingSkills        String[]  @default([])
  extraRelevantSkills  String[]  @default([])
  selectedProjectIds   String[]  @default([])
  selectedCourseIds    String[]  @default([])
  selectedCertificationIds String[] @default([])
  generatedResumeId    String?
  confirmedSeniority   String    @default("unknown")
  inferredSeniority    String    @default("unknown")
  aderenciaBase        Int       @default(0)
  aderenciaFinal       Int       @default(0)
  skillsScore          Int       @default(0)
  projectsScore        Int       @default(0)
  seniorityPenalty     Int       @default(0)
  warnings             String[]  @default([])
  scoringVersion       String    @default("deterministic-v1")
  status               String    @default("draft")
  appliedAt            DateTime?
  notes                String    @default("")
  version              Int       @default(1)
  parentAnalysisId     String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  selectedSubprofile CareerProfile?   @relation(fields: [selectedSubprofileId], references: [id], onDelete: SetNull)
  generatedResume    OptimizedResume? @relation("GeneratedAnalysisResume", fields: [generatedResumeId], references: [id], onDelete: SetNull)
  parentAnalysis     JobAnalysis?     @relation("AnalysisVersions", fields: [parentAnalysisId], references: [id], onDelete: SetNull)
  versions           JobAnalysis[]    @relation("AnalysisVersions")
  applications       Job[]

  @@index([userId, createdAt])
  @@index([userId, selectedSubprofileId, createdAt(sort: Desc)], map: "JobAnalysis_user_profile_created_desc_idx")
  @@index([selectedSubprofileId])
  @@index([status])
}

model SharedMatchedJob {
  id        String   @id @default(uuid())
  jobTitle  String
  company   String
  jobUrl    String
  jobDescription String @default("")
  confirmedSeniority String @default("unknown")
  inferredSeniority String @default("unknown")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([jobTitle])
  @@index([company])
}

model GoogleDocsExport {
  id                String   @id @default(uuid())
  optimizedResumeId String
  googleDocId       String   @default("")
  googleDocUrl      String   @default("")
  permissionType    String   @default("private")
  exportedAt        DateTime @default(now())

  optimizedResume OptimizedResume @relation(fields: [optimizedResumeId], references: [id], onDelete: Cascade)

  @@index([optimizedResumeId])
}

model ResumeFile {
  id            String   @id @default(uuid())
  userId        String
  profileId     String?
  fileName      String
  mimeType      String
  sizeBytes     Int
  content       Bytes
  extractedText String   @default("")
  createdAt     DateTime @default(now())

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile          CareerProfile?    @relation(fields: [profileId], references: [id], onDelete: SetNull)
  optimizedResumes OptimizedResume[]

  @@index([userId])
  @@index([profileId])
  @@index([createdAt])
}

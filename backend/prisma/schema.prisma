datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String @id @default(uuid())
  name         String
  email        String @unique
  password     String
  title        String @default("")
  emailContact String @default("")
  phone        String @default("")
  location     String @default("")
  linkedin     String @default("")
  github       String @default("")
  lattes       String @default("")
  summary      String @default("")

  jobs             Job[]
  careerProfiles   CareerProfile[]
  skills           Skill[]
  projects         Project[]
  experiences      Experience[]
  courses          Course[]
  certifications   Certification[]
  languages        Language[]
  optimizedResumes OptimizedResume[]
  resumeFiles      ResumeFile[]
  authSessions     AuthSession[]
}

model CareerProfile {
  id           String   @id @default(uuid())
  userId       String
  profileName  String
  isGlobal     Boolean  @default(false)
  name         String
  title        String   @default("")
  emailContact String   @default("")
  phone        String   @default("")
  location     String   @default("")
  linkedin     String   @default("")
  github       String   @default("")
  lattes       String   @default("")
  summary      String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills           Skill[]
  projects         Project[]
  experiences      Experience[]
  courses          Course[]
  certifications   Certification[]
  languages        Language[]
  optimizedResumes OptimizedResume[]
  resumeFiles      ResumeFile[]

  @@index([userId])
}

model Job {
  id       String @id @default(uuid())
  titulo   String
  empresa  String
  linkVaga String
  linkCV   String

  data   DateTime
  status String
  fase   String

  acaoNecessaria Boolean
  qualAcao       String?
  prazoAcao      DateTime?

  feedbackBool Boolean
  feedbackTxt  String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, data])
  @@index([status])
  @@index([fase])
}

model AuthSession {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Skill {
  id        String   @id @default(uuid())
  name      String
  userId    String
  profileId String?
  createdAt DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile CareerProfile? @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, name])
  @@index([userId])
  @@index([profileId])
}

model Project {
  id            String   @id @default(uuid())
  title         String
  description   String
  repositoryUrl String   @default("")
  deployUrl     String   @default("")
  userId        String
  profileId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile      CareerProfile?      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  technologies ProjectTechnology[]

  @@index([userId])
  @@index([profileId])
}

model ProjectTechnology {
  id        String @id @default(uuid())
  name      String
  projectId String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@index([projectId])
}

model Experience {
  id          String   @id @default(uuid())
  company     String
  role        String
  period      String
  description String
  userId      String
  profileId   String?
  createdAt   DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile CareerProfile? @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([profileId])
}

model Course {
  id          String   @id @default(uuid())
  title       String
  institution String   @default("")
  period      String   @default("")
  description String   @default("")
  userId      String
  profileId   String?
  createdAt   DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile CareerProfile? @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([profileId])
}

model Certification {
  id            String   @id @default(uuid())
  title         String
  issuer        String   @default("")
  period        String   @default("")
  credentialUrl String   @default("")
  userId        String
  profileId     String?
  createdAt     DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile CareerProfile? @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([profileId])
}

model Language {
  id        String   @id @default(uuid())
  name      String
  level     String   @default("")
  userId    String
  profileId String?
  createdAt DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile CareerProfile? @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([profileId])
}

model OptimizedResume {
  id                  String   @id @default(uuid())
  userId              String
  targetTitle         String
  jobDescription      String
  score               Int
  suggestedSummary    String
  selectedProjects    Json
  matchedSkills       String[] @default([])
  missingSkills       String[] @default([])
  matchedTechnologies String[] @default([])
  missingTechnologies String[] @default([])
  resumeFileId        String?
  profileId           String?
  generatedPdf        Bytes?
  generatedFileName   String?
  createdAt           DateTime @default(now())

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile    CareerProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  resumeFile ResumeFile?    @relation(fields: [resumeFileId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([profileId])
  @@index([resumeFileId])
  @@index([createdAt])
}

model ResumeFile {
  id            String   @id @default(uuid())
  userId        String
  profileId     String?
  fileName      String
  mimeType      String
  sizeBytes     Int
  content       Bytes
  extractedText String   @default("")
  createdAt     DateTime @default(now())

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile          CareerProfile?    @relation(fields: [profileId], references: [id], onDelete: SetNull)
  optimizedResumes OptimizedResume[]

  @@index([userId])
  @@index([profileId])
  @@index([createdAt])
}
